# ==========================================================================
# IT DEPARTMENT ONLINE VOTING - BACKEND CONFIGURATIONS
# ==========================================================================

# Express Port (Default: 5000)
PORT=5000

# --------------------------------------------------------------------------
# OPTION A: DUAL RESEND CLOUD API WITH AUTOMATIC FAILOVER (100% Free)
# --------------------------------------------------------------------------
# Resend Free Tier limits sandbox accounts to 100 emails/day.
# If the primary Resend API key hits its limit, the server will
# automatically failover and send using the secondary Resend API key.

RESEND_API_KEY_PRIMARY=re_primary_key_here
RESEND_API_KEY_SECONDARY=re_secondary_key_here

# --------------------------------------------------------------------------
# OPTION B: DUAL GMAIL SMTP WITH AUTOMATIC FAILOVER (100% Free)
# --------------------------------------------------------------------------
# If the primary Gmail account crosses its 500 emails/day limit, 
# the server will automatically failover and send from the secondary account.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# Primary Gmail Account
SMTP_USER_PRIMARY=first.election.account@gmail.com
SMTP_PASS_PRIMARY=xxxx_xxxx_xxxx_xxxx

# Secondary Gmail Account (Failover account)
SMTP_USER_SECONDARY=second.election.account@gmail.com
SMTP_PASS_SECONDARY=yyyy_yyyy_yyyy_yyyy

# --------------------------------------------------------------------------
# OPTION C: MOCK DEVELOPER MODE (Default)
# --------------------------------------------------------------------------
# If no login credentials are set above, the server logs OTP codes 
# in the terminal logs and displays them in the browser mock banner.
